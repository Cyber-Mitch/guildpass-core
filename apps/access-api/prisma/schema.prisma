datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- existing models above (User, Wallet, Community, Member, Policy, etc.) ---

enum EventType {
  ACCESS_CHECK
  MEMBERSHIP_CREATED
  MEMBERSHIP_UPDATED
  MEMBERSHIP_DELETED
  POLICY_EVALUATION
  OTHER
}

model AuditEvent {
  id          String   @id @default(uuid())
  eventType   EventType
  walletId    String?  // optional: some events may not have a wallet
  communityId String?  // optional
  resource    String?
  policyRule  String?
  decision    String?  // e.g. "ALLOW", "DENY"
  reasonCode  String?  // machine-readable code for decision
  beforeState Json?
  afterState  Json?
  createdAt   DateTime @default(now())

  @@index([walletId])
  @@index([communityId])
  @@index([createdAt])
}
