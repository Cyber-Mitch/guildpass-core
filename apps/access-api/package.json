{
  "name": "access-api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "openapi:generate": "ts-node scripts/generate-openapi.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:check": "prisma migrate status",
    "prisma:ci": "pnpm run prisma:validate && pnpm run prisma:generate && pnpm run prisma:migrate:deploy && pnpm run prisma:migrate:check",
    "seed": "ts-node prisma/seed.ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^2.0.1",
    "@guildpass/policy-engine": "workspace:*",
    "@guildpass/shared-types": "workspace:*",
    "@prisma/client": "^5.14.0",
    "fastify": "^4.25.0",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/uuid": "^11.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
